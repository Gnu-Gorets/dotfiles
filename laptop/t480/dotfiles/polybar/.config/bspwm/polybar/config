# bspwm


[colors]
background = #000000
foreground = #ffffff
accent = #798BC7
text = #9baec8
light = #d5d6d7
suffix = #ff0404

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/top]
width = 100%
height = 24
offset-x = 0
offset-y = 0
radius = 0
fixed-center = true
bottom = false
locale = en_GB.UTF-8

background = ${colors.background}
foreground = ${colors.text}

line-size = 0.5
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 1
padding-right = 1

module-margin-left = 0
module-margin-right = 1

font-0 = "Droid Sans:size=10;1"
font-1 = "Symbols Nerd Font:size=10;1"

modules-left = cpu memory temperature uparch title
modules-center = bspwm
modules-right = tor bluetooth pipewire brightness battery date xkeyboard power

cursor-click = pointer
cursor-scroll = ns-resize

wm-restack = bspwm
override-redirect = false
enable-ipc = true

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.accent}
label = %percentage%%

[module/memory]
type = internal/memory
interval = 10
format-prefix = " "
format-prefix-foreground = ${colors.accent}

[module/temperature]
type = internal/temperature
thermal-zone = 3
warn-temperature = 75

format = <ramp> <label>
format-warn = <ramp> <label-warn>

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.suffix}

ramp-0 = 
ramp-1 = 
ramp-2 = 
ramp-foreground = ${colors.accent}

[module/uparch]
type = custom/script
exec = ~/.config/bspwm/polybar/uparch.sh
interval = 60
format-prefix = " "
format-prefix-foreground = ${colors.accent}
format-padding = 0
click-left = "alacritty -T UpArch -e ~/.bin/pacui &"

[module/title]
type = internal/xwindow
format-padding = 0
label = "%title:0:60:...%"

[module/bspwm]
type = internal/bspwm

ws-icon-0 = I;term
ws-icon-1 = II;web
ws-icon-2 = III;code
ws-icon-3 = IV;file
ws-icon-4 = V;chat
ws-icon-5 = VI;media
ws-icon-6 = VII;office
ws-icon-7 = VIII;xpipe
ws-icon-8 = IX;vm
ws-icon-9 = X;vault

format = <label-state>

label-focused = %icon%
label-focused-background = ${colors.accent}
label-focused-foreground = ${xrdb:color7}
label-focused-padding = 2

label-occupied = %icon%
label-occupied-foreground = ${colors.accent}
label-occupied-padding = 1

label-urgent = %icon%
label-urgent-foreground = ${xrdb:color5}
label-urgent-padding = 1

label-empty = %icon%
label-empty-foreground = ${colors.text}
label-empty-padding = 1

[module/tor]
type = custom/script
exec = ~/.config/bspwm/status tor
interval = 6
format = <label>
format-prefix = " "
format-prefix-foreground = ${colors.accent}
format-padding = 0
click-left = "systemctl restart tor &"
click-right = "systemctl stop tor &"

[module/bluetooth]
type = custom/script
exec = ~/.config/bspwm/polybar/rofi_bluetooth/rofi-bluetooth --status
interval = 2
click-left = ~/.config/bspwm/polybar/rofi_bluetooth/rofi-bluetooth

[module/brightness]
type = custom/script
exec = xbacklight -get | awk '{printf "%.0f%%\n", $1}'
interval = 1.5
format-prefix = " "
format-prefix-foreground = ${colors.accent}

[module/pipewire]
type = internal/pulseaudio
format-volume = <ramp-volume> <label-volume>
format-muted = 0%
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
ramp-volume-foreground = ${colors.foreground}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC

format-charging = 󰂏 <label-charging>
format-charging-foreground = ${colors.battery}
format-charging-underline = ${colors.battery}
label-charging = %percentage%
label-charging-foreground = ${colors.foreground}

format-discharging = 󱊢 <label-discharging>
format-discharging-foreground = ${colors.battery}
format-discharging-underline = ${self.format-charging-underline}
label-discharging = %percentage%

format-full = 󱊣 <label-full>
format-full-foreground = ${colors.battery}
format-full-underline = ${self.format-charging-underline}
label-full = %percentage%

[module/date]
type = internal/date
interval = 10

date = %a %d.%m.%Y
time = %H:%M
label = "%date%  %time%"

format = <label>
format-prefix = " "
format-underline = ${colors.date}

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
# blacklist-1 = caps lock

format-prefix = " "
label-layout = %layout%

label-indicator-padding = 2
label-indicator-margin = 1

[module/power]
type = custom/text
format = 
content-foreground = ${colors.accent}
content-background = ${xrdb:color0}
content-padding = 1
click-left = ~/.config/bspwm/power
